
{
  "entities": {
    "CompanyProfile": {
      "title": "CompanyProfile",
      "description": "Represents a company/business entity in the Maldives.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "signatureUrl": { "type": "string", "format": "uri" },
        "authorizedSignatory": { "type": "string" },
        "gstNumber": { "type": "string" },
        "bankDetails": {
          "type": "object",
          "properties": {
            "bankName": { "type": "string" },
            "accountName": { "type": "string" },
            "accountNumber": { "type": "string" },
            "branchName": { "type": "string" }
          }
        }
      },
      "required": ["id", "name", "address", "email", "phone"]
    },
    "Document": {
      "title": "Document",
      "description": "Financial document (Invoice, Quotation, Tender, or BOQ).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "profileId": { "type": "string" },
        "type": { "type": "string", "enum": ["invoice", "quotation", "tender", "boq"] },
        "number": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "clientAddress": { "type": "string" },
        "taxRate": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string" },
        "currency": { "type": "string" },
        "subtotal": { "type": "number" },
        "taxAmount": { "type": "number" },
        "total": { "type": "number" },
        "notes": { "type": "string" },
        "terms": { "type": "string" }
      },
      "required": ["id", "profileId", "type", "number", "clientName", "total"]
    },
    "DocumentItem": {
      "title": "DocumentItem",
      "description": "Line item within a document.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "costCode": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" }
      }
    },
    "Client": {
      "title": "Client",
      "description": "Customer or agency details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "profileId": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "gstNumber": { "type": "string" }
      }
    },
    "LibraryDocument": {
      "title": "LibraryDocument",
      "description": "Shared company documents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "profileId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "data": { "type": "string" },
        "category": { "type": "string" },
        "uploadedAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": "CompanyProfile",
      "description": "Top-level company profiles."
    },
    "/companies/{companyId}/documents/{docId}": {
      "schema": "Document",
      "description": "Invoices and proposals for a company."
    },
    "/companies/{companyId}/clients/{clientId}": {
      "schema": "Client",
      "description": "Clients associated with a company."
    },
    "/companies/{companyId}/library/{libId}": {
      "schema": "LibraryDocument",
      "description": "Company document library."
    }
  }
}
