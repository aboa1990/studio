{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user account within the system, used for authentication and authorization.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string" },
        "companyProfileId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "companyProfileId"]
    },
    "CompanyProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CompanyProfile",
      "type": "object",
      "description": "Stores general information and branding details for a company.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "ownerUserId": { "type": "string" },
        "logo_url": { "type": "string" },
        "signature_url": { "type": "string" },
        "seal_url": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "name", "ownerUserId"]
    },
    "LibraryDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LibraryDocument",
      "type": "object",
      "description": "A reusable document or attachment stored in the company library.",
      "properties": {
        "id": { "type": "string" },
        "profile_id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "data": { "type": "string" },
        "uploaded_at": { "type": "string" }
      },
      "required": ["id", "profile_id", "name", "data"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "User authorization context mapping UID to companyProfileId."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "entityName": "CompanyProfile",
          "description": "Top-level company identity."
        }
      },
      {
        "path": "/library_documents/{docId}",
        "definition": {
          "entityName": "LibraryDocument",
          "description": "Reusable assets shared across company documents."
        }
      }
    ]
  }
}