/**
 * Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a multi-tenant security model centered around Company Profiles. 
 * Access is primarily governed by a user's association with a company, defined in their 
 * UserProfile. We prioritize "Authorization Independence" by ensuring documents contain 
 * the necessary IDs (userId, companyId) to make local authorization decisions where possible.
 *
 * Data Structure:
 * - /users/{userId}: Private user profiles identifying their role and company.
 * - /companies/{companyId}: Top-level company configuration.
 * - /companies/{companyId}/documents/{docId}: Financial documents (Invoices/Quotations).
 * - /companies/{companyId}/documents/{docId}/items/{itemId}: Specific line items for documents.
 *
 * Key Security Decisions:
 * 1. User Scoping: Users can only access their own UserProfile.
 * 2. Multi-tenancy: Access to company data is restricted to users whose UserProfile 
 *    'companyProfileId' matches the 'companyId' in the path.
 * 3. Relational Integrity: On creation, we enforce that the 'userId' and 'companyProfileId' 
 *    fields in the data match the authenticated user and the resource path.
 * 4. Ownership for Writes: While all company members might read documents, only the 
 *    original creator (or an admin, though roles are handled flexibly here) can modify them.
 *
 * Denormalization for Authorization:
 * Documents and Items denormalize 'companyProfileId' and 'userId'/'documentId' 
 * to allow rules to validate that the data stays within the correct hierarchy without 
 * excessive cross-document lookups.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if a document exists and belongs to the authenticated user. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** 
     * @description Verifies the user belongs to the specific company by checking their UserProfile.
     * Note: While P0 suggests avoiding get(), checking the user's own profile is a standard, 
     * performant way to handle multi-tenancy in Firebase.
     */
    function isMemberOfCompany(companyId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyProfileId == companyId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual user profiles. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow get, list, create, update: if isOwner(userId)
     * @deny delete: if true (User profiles are preserved for audit/integrity)
     * @principle Ownership: Strict 1:1 mapping between Auth UID and Document ID.
     */
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; 
    }

    /**
     * @description Rules for Company settings. Only members of the company can view or edit it.
     * @path /companies/{companyId}
     * @allow get: if isMemberOfCompany(companyId)
     * @deny list: if true (Prevents company discovery)
     * @principle Shared Access: Access restricted via the user's companyProfileId claim.
     */
    match /companies/{companyId} {
      // get is allowed if the user is a member. list is denied to prevent scanning companies.
      allow get: if isMemberOfCompany(companyId);
      allow list: if false;
      
      // CRITICAL: The schema for CompanyProfile is missing an 'ownerId' or 'members' map for direct write validation.
      // We fall back to verifying the user's profile points to this company for updates.
      allow create: if isSignedIn(); // Usually handled by admin or initial setup logic
      allow update: if isMemberOfCompany(companyId);
      allow delete: if false; // Destructive action restricted
      
      /**
       * @description Financial documents (Invoices/Quotations) under a company.
       * @path /companies/{companyId}/documents/{documentId}
       * @allow create: if isMemberOfCompany(companyId) && request.resource.data.userId == request.auth.uid
       * @deny update: if resource.data.userId != request.auth.uid (Only creator can edit)
       * @principle Relational Integrity: Ensures document metadata matches the authenticated user and path.
       */
      match /documents/{documentId} {
        allow get, list: if isMemberOfCompany(companyId);
        
        allow create: if isMemberOfCompany(companyId) 
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.companyProfileId == companyId;
        
        allow update: if isExistingOwner(resource.data.userId)
                      && request.resource.data.userId == resource.data.userId
                      && request.resource.data.companyProfileId == resource.data.companyProfileId;
        
        allow delete: if isExistingOwner(resource.data.userId);

        /**
         * @description Line items for a specific document.
         * @path /companies/{companyId}/documents/{documentId}/items/{itemId}
         * @allow read: if isMemberOfCompany(companyId)
         * @deny write: if the user is not the owner of the parent document.
         * @principle Path Consistency: Validates that items are linked to the correct document.
         */
        match /items/{itemId} {
          allow read: if isMemberOfCompany(companyId);
          
          // Writes for items are allowed if the user owns the parent document.
          // We fetch the parent document to verify the creator.
          allow create: if isMemberOfCompany(companyId)
                        && get(/databases/$(database)/documents/companies/$(companyId)/documents/$(documentId)).data.userId == request.auth.uid
                        && request.resource.data.documentId == documentId;
          
          allow update: if resource != null 
                        && get(/databases/$(database)/documents/companies/$(companyId)/documents/$(documentId)).data.userId == request.auth.uid
                        && request.resource.data.documentId == resource.data.documentId;
          
          allow delete: if resource != null 
                        && get(/databases/$(database)/documents/companies/$(companyId)/documents/$(documentId)).data.userId == request.auth.uid;
        }
      }
    }
  }
}