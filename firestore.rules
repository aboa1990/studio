rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ForgeDocs Management Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a multi-tenant security model where data is strictly partitioned by Company ID. 
     * It leverages "Authorization Independence" via denormalization: essential fields like 'companyProfileId' 
     * are stored on every document to allow rules to evaluate access without performing deep hierarchical lookups.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserProfile() {
      // Safely attempt to get the user profile
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function belongsToCompany(companyId) {
      // Checks if the user's profile explicitly links them to this company
      return isSignedIn() && getUserProfile().companyProfileId == companyId;
    }

    function isCompanyOwner(companyId) {
      // Checks if the user is the technical creator/owner of the company document
      return isSignedIn() && (resource == null || resource.data.ownerUserId == request.auth.uid);
    }

    // --- Collection Rules ---

    /**
     * @path /user_profiles/{userId}
     */
    match /user_profiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @path /companies/{companyId}
     */
    match /companies/{companyId} {
      // Allow list if the query filters by the user's UID as owner
      allow list: if isSignedIn() && request.query.limit <= 100; 
      // Allow get if they belong to it OR they are the owner record holder
      allow get: if isSignedIn() && (belongsToCompany(companyId) || resource.data.ownerUserId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (belongsToCompany(companyId) || resource.data.ownerUserId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
    }

    /**
     * @path /companies/{companyId}/clients/{clientId}
     */
    match /companies/{companyId}/clients/{clientId} {
      allow get, list: if belongsToCompany(companyId);
      allow create: if belongsToCompany(companyId) && request.resource.data.companyProfileId == companyId;
      allow update: if belongsToCompany(companyId) && request.resource.data.companyProfileId == companyId;
      allow delete: if belongsToCompany(companyId);
    }

    /**
     * @path /companies/{companyId}/documents/{documentId}
     */
    match /companies/{companyId}/documents/{documentId} {
      allow get, list: if belongsToCompany(companyId);
      allow create: if belongsToCompany(companyId) && request.resource.data.companyProfileId == companyId;
      allow update: if belongsToCompany(companyId) && request.resource.data.companyProfileId == companyId;
      allow delete: if belongsToCompany(companyId);
    }

    /**
     * @path /companies/{companyId}/documents/{documentId}/items/{documentItemId}
     */
    match /companies/{companyId}/documents/{documentId}/items/{documentItemId} {
      allow get, list: if belongsToCompany(companyId);
      allow create, update: if belongsToCompany(companyId) && request.resource.data.companyProfileId == companyId;
      allow delete: if belongsToCompany(companyId);
    }
  }
}