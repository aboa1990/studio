rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ForgeDocs Management Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Safely checks if a user profile exists and belongs to a company
    function userBelongsToCompany(companyId) {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      return isSignedIn() && exists(profilePath) && get(profilePath).data.companyProfileId == companyId;
    }

    // --- Collection Rules ---

    /**
     * @path /user_profiles/{userId}
     */
    match /user_profiles/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow list, delete: if false;
    }

    /**
     * @path /companies/{companyId}
     */
    match /companies/{companyId} {
      // Allow listing companies where the user is the owner
      // Or if they have a profile pointing to this company
      allow list: if isSignedIn() && (
        (resource != null && resource.data.ownerUserId == request.auth.uid) ||
        userBelongsToCompany(companyId)
      );
      
      // Allow get if owner or authorized staff
      allow get: if isSignedIn() && (
        (resource != null && resource.data.ownerUserId == request.auth.uid) || 
        userBelongsToCompany(companyId)
      );
      
      // Allow creation if setting themselves as owner
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      
      // Allow update if owner or authorized staff
      allow update: if isSignedIn() && (
        (resource != null && resource.data.ownerUserId == request.auth.uid) || 
        userBelongsToCompany(companyId)
      );
      
      // Only the primary owner can delete the company record
      allow delete: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;

      /**
       * Sub-collections inherit ownership and company link checks
       */
      match /clients/{clientId} {
        allow get, list: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));
        allow create, update: if isSignedIn() && 
                                (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId)) 
                                && (request.resource.data.profile_id == companyId);
        allow delete: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));
      }

      match /documents/{documentId} {
        allow get, list: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));
        allow create, update: if isSignedIn() && 
                                (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId)) 
                                && (request.resource.data.profile_id == companyId);
        allow delete: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));

        match /items/{itemId} {
          allow get, list: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));
          allow create, update, delete: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));
        }

        match /email_logs/{logId} {
          allow get, list: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));
          allow create: if isSignedIn() && (get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid || userBelongsToCompany(companyId));
        }
      }
    }

    /**
     * @path /library_documents/{docId}
     */
    match /library_documents/{docId} {
      // Library docs are secured by the profile_id they are uploaded to
      allow list: if isSignedIn() && (
        get(/databases/$(database)/documents/companies/$(resource.data.profile_id)).data.ownerUserId == request.auth.uid ||
        userBelongsToCompany(resource.data.profile_id)
      );
      allow get: if isSignedIn() && (
        get(/databases/$(database)/documents/companies/$(resource.data.profile_id)).data.ownerUserId == request.auth.uid ||
        userBelongsToCompany(resource.data.profile_id)
      );
      allow create, update: if isSignedIn() && (
        get(/databases/$(database)/documents/companies/$(request.resource.data.profile_id)).data.ownerUserId == request.auth.uid ||
        userBelongsToCompany(request.resource.data.profile_id)
      );
      allow delete: if isSignedIn() && (
        get(/databases/$(database)/documents/companies/$(resource.data.profile_id)).data.ownerUserId == request.auth.uid ||
        userBelongsToCompany(resource.data.profile_id)
      );
    }
  }
}