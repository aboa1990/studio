rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ForgeDocs Management Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserProfile() {
      // Safely get the user's authorization profile
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isCompanyOwner(companyId) {
      // Checks if the user is the direct owner of the company document
      return isSignedIn() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUserId == request.auth.uid;
    }

    function belongsToCompany(companyId) {
      // Checks if the user's profile explicitly links them to this company
      // OR if they are the direct owner
      return isSignedIn() && (getUserProfile().companyProfileId == companyId || isCompanyOwner(companyId));
    }

    // --- Collection Rules ---

    /**
     * @path /user_profiles/{userId}
     */
    match /user_profiles/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow list, delete: if false;
    }

    /**
     * @path /companies/{companyId}
     */
    match /companies/{companyId} {
      // Allow listing companies where the user is the owner
      allow list: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;
      
      // Allow get if owner or linked via authorization profile
      allow get: if isSignedIn() && (resource.data.ownerUserId == request.auth.uid || belongsToCompany(companyId));
      
      // Allow creation if setting themselves as owner
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      
      // Allow update if owner or authorized staff
      allow update: if isSignedIn() && (resource.data.ownerUserId == request.auth.uid || belongsToCompany(companyId));
      
      // Only the primary owner can delete the company record
      allow delete: if isSignedIn() && resource.data.ownerUserId == request.auth.uid;

      /**
       * Sub-collections inherit the belongsToCompany check
       */
      match /clients/{clientId} {
        allow get, list: if belongsToCompany(companyId);
        allow create, update: if belongsToCompany(companyId) && request.resource.data.profile_id == companyId;
        allow delete: if belongsToCompany(companyId);
      }

      match /documents/{documentId} {
        allow get, list: if belongsToCompany(companyId);
        allow create, update: if belongsToCompany(companyId) && request.resource.data.profile_id == companyId;
        allow delete: if belongsToCompany(companyId);

        match /items/{itemId} {
          allow get, list: if belongsToCompany(companyId);
          allow create, update: if belongsToCompany(companyId) && request.resource.data.profile_id == companyId;
          allow delete: if belongsToCompany(companyId);
        }

        match /email_logs/{logId} {
          allow get, list: if belongsToCompany(companyId);
          allow create: if belongsToCompany(companyId);
        }
      }
    }

    /**
     * @path /library_documents/{docId}
     */
    match /library_documents/{docId} {
      // Library docs are secured by the profile_id they are uploaded to
      allow list: if isSignedIn() && belongsToCompany(resource.data.profile_id);
      allow get: if isSignedIn() && belongsToCompany(resource.data.profile_id);
      allow create, update: if isSignedIn() && belongsToCompany(request.resource.data.profile_id);
      allow delete: if isSignedIn() && belongsToCompany(resource.data.profile_id);
    }
  }
}