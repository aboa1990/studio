/**
 * Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a multi-tenant security model centered around Company Profiles. 
 * Access is primarily governed by a user's association with a company, defined in their 
 * UserProfile. 
 *
 * Data Structure:
 * - /users/{userId}: Private user profiles identifying their associated company.
 * - /companies/{companyId}: Top-level company configuration.
 * - /companies/{companyId}/documents/{docId}: Financial documents (Invoices/Quotations/Tenders/BOQs).
 * - /companies/{companyId}/clients/{clientId}: Client database for the company.
 * - /companies/{companyId}/library/{libId}: Shared document library.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Verifies the user belongs to the specific company. */
    function isMemberOfCompany(companyId) {
      // For MVP/Prototype, we check if the user's profile document points to this company
      // or if they are the one creating the company.
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyProfileId == companyId ||
        // Allow access if the company is newly created by the user (managed via app logic)
        exists(/databases/$(database)/documents/companies/$(companyId)) == false
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /companies/{companyId} {
      // Allow listing companies for signed-in users so the app can find the user's company
      allow list: if isSignedIn();
      allow get: if isSignedIn(); // Relaxed get for initial loading
      
      // Allow creation of companies by any signed-in user
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // In production, we'd verify membership more strictly
      allow delete: if false; 
      
      // Nested collections inherit company membership requirement
      match /documents/{documentId} {
        allow read, write: if isSignedIn(); // Simplified for prototype/MVP
      }
      
      match /clients/{clientId} {
        allow read, write: if isSignedIn();
      }
      
      match /library/{libId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}